# Copy this file to ../battlenet.env and adjust it for your machine.
# Do not commit battlenet.env; it may contain local paths.

# Optional. If unset, scripts try to find the newest Proton/GE-Proton under Steam.
# BNET_PROTON="$HOME/.steam/debian-installation/compatibilitytools.d/GE-Proton10-34/proton"

# Optional. Steam client root used by Proton.
BNET_STEAM_ROOT="$HOME/.steam/debian-installation"

# Proton compat data path. This is the Wine prefix container Proton will use.
BNET_COMPAT_DATA_PATH="$PWD/proton-battlenet"

# Battle.net client path inside the Proton prefix.
BNET_EXE_PATH="$BNET_COMPAT_DATA_PATH/pfx/drive_c/Program Files (x86)/Battle.net/Battle.net.exe"

# Optional local installer path. The installer itself is intentionally not tracked.
BNET_INSTALLER_PATH="$PWD/installers/Battle.net-Setup.exe"

# 1 = show GPU picker when an interactive terminal is available.
BNET_ENABLE_GPU_SELECT=1

# Optional exact GPU name as seen by vulkaninfo / DXVK.
# GPU_SELECT_DEFAULT="NVIDIA GeForce RTX 3080"

# Proton's Xalia helper can crash in some non-Steam desktop launches.
PROTON_USE_XALIA=0

# auto/on/off. Enables conservative DXVK/Proton performance env flags by default.
BNET_PERFORMANCE_MODE=auto

# Set to 1 to show DXVK FPS HUD.
BNET_DXVK_HUD=0

